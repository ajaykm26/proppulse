# =============================================================================
# PropPulse Frontend — Environment Variables
# Copy this to .env and fill in your values
# VITE_ prefix is required for Vite to expose these to the browser
# =============================================================================

# Clerk publishable key (safe to expose client-side)
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."

# Backend API URL (for direct fetch calls if not using the Vite proxy)
VITE_API_URL="http://localhost:3001"
